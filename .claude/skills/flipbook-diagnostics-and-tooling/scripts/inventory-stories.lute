#!/usr/bin/env lute
-- Inventory all stories and specs in the workspace
-- Usage: lute run scripts/inventory-stories.lute
-- Outputs a summary of story/spec counts per workspace member

local fs = require("@std/fs")
local path = require("@std/path")

local WORKSPACE_ROOT = "/Users/marin/Code/flipbook/workspace"

local function countFiles(dir, pattern)
	if not fs.dir(dir) then
		return 0, {}
	end

	local count = 0
	local files = {}

	for item in fs.dir(dir) do
		local itemPath = path.join(dir, item)
		if fs.metadata(itemPath).kind == "file" then
			if string.match(item, pattern) then
				count = count + 1
				table.insert(files, item)
			end
		elseif fs.metadata(itemPath).kind == "dir" then
			local subCount, subFiles = countFiles(itemPath, pattern)
			count = count + subCount
			for _, file in ipairs(subFiles) do
				table.insert(files, path.join(item, file))
			end
		end
	end

	return count, files
end

local members = {}

-- Iterate workspace members
for item in fs.dir(WORKSPACE_ROOT) do
	local itemPath = path.join(WORKSPACE_ROOT, item)
	if fs.metadata(itemPath).kind == "dir" and not string.match(item, "^%.") then
		local storyCount, stories = countFiles(itemPath, "%.story%.luau$")
		local specCount, specs = countFiles(itemPath, "%.spec%.luau$")

		table.insert(members, {
			name = item,
			stories = storyCount,
			specs = specCount,
		})
	end
end

-- Sort by name
table.sort(members, function(a, b)
	return a.name < b.name
end)

-- Print summary
print("\n=== Flipbook Story & Spec Inventory ===\n")
print(string.format("%-30s %10s %10s", "Workspace Member", "Stories", "Specs"))
print(string.rep("-", 52))

local totalStories = 0
local totalSpecs = 0

for _, member in ipairs(members) do
	print(string.format("%-30s %10d %10d", member.name, member.stories, member.specs))
	totalStories = totalStories + member.stories
	totalSpecs = totalSpecs + member.specs
end

print(string.rep("-", 52))
print(string.format("%-30s %10d %10d\n", "TOTAL", totalStories, totalSpecs))
