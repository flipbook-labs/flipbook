{
  "luau-lsp.sourcemap.rojoProjectFile": "sourcemap.project.json",
  "luau-lsp.ignoreGlobs": [
    "**/_Index/**",
    "**/build/**",
    "**/*Packages/**",
    "**/.lute/typedefs/**"
  ],

  // Prettier formats docs only: the config lives at docs/.prettierrc.json, and
  // requireConfig means files without a resolvable config (e.g. root AGENTS.md,
  // Luau) are left alone. Luau keeps using stylua.
  "prettier.requireConfig": true,
  "[markdown]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode",
    "editor.formatOnSave": true
  },
  "[json]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode",
    "editor.formatOnSave": true
  },
  "[jsonc]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode",
    "editor.formatOnSave": true
  },
  "[yaml]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode",
    "editor.formatOnSave": true
  },
  "[typescript]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode",
    "editor.formatOnSave": true
  },
  "[typescriptreact]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode",
    "editor.formatOnSave": true
  },
  "[css]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode",
    "editor.formatOnSave": true
  }
}
